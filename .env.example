# Supabase connection string (paste from Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Security
JWT_SECRET=replace-with-a-long-random-string-min-32-chars

# Paystack
PAYSTACK_SECRET=sk_test_acaee558901f19bc14c52b5b1b7473d05bc41162

# Admin panel
ADMIN_PASSWORD=choose-a-strong-password

# SMTP (email sending)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USER=your@domain.com
MAIL_PASS=your-mail-password
MAIL_FROM=your@domain.com
